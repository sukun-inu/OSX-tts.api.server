# OSX TTS API — 環境変数サンプル
# このファイルを .env にコピーして利用環境に合わせて調整する:
#   cp .env.example .env
# すべて接頭辞 TTS_ 付き。未設定の項目は app/config.py の既定値が使われる。

# --- サーバー ---------------------------------------------------------------
TTS_HOST=127.0.0.1
TTS_PORT=8000

# --- 音声ファイル -----------------------------------------------------------
# 生成音声の保存先。nginx の alias と同じ場所を指すこと。
# 相対パスは「サーバー起動時のカレントディレクトリ」基準で絶対パスに解決される。
TTS_AUDIO_DIR=audio
# レスポンスの url を絶対URLで返す場合に設定 (例: http://192.168.1.50)。
# 空の場合は "/audio/xxxx.m4a" のような相対パスを返す。
TTS_PUBLIC_BASE_URL=

# --- 音声生成の既定値 -------------------------------------------------------
# 空 = say のシステム既定音声を使用 (例: Kyoko)
TTS_DEFAULT_VOICE=
# 0 = say の既定速度を使用 (語/分)
TTS_DEFAULT_RATE=0
# 既定の出力フォーマット: aiff / wav / m4a / mp3
TTS_DEFAULT_FORMAT=m4a

# --- 入力制限 ---------------------------------------------------------------
TTS_MAX_TEXT_LENGTH=2000
TTS_RATE_MIN=100
TTS_RATE_MAX=400

# --- キャッシュ・クリーンアップ ---------------------------------------------
# 生成音声の保持時間(秒)。これを超えたファイルは自動削除される。
TTS_AUDIO_TTL_SECONDS=3600
# クリーンアップ処理の実行間隔(秒)
TTS_CLEANUP_INTERVAL_SECONDS=600

# --- 同時実行・タイムアウト -------------------------------------------------
# 同時に実行する say / ffmpeg プロセスの上限
TTS_MAX_CONCURRENT_SYNTHESIS=4
# 1回の音声生成のタイムアウト(秒)
TTS_SYNTHESIS_TIMEOUT_SECONDS=30

# --- 外部コマンド -----------------------------------------------------------
# mp3 出力時に使用。PATH 上にない場合は絶対パスを指定する。
TTS_FFMPEG_PATH=ffmpeg
