# OSX TTS API — 環境変数サンプル
# このファイルを .env にコピーして利用環境に合わせて調整する:
#   cp .env.example .env
# すべて接頭辞 TTS_ 付き。未設定の項目は app/config.py の既定値が使われる。

# --- サーバー ---------------------------------------------------------------
TTS_HOST=127.0.0.1
TTS_PORT=8000

# --- 音声ファイル -----------------------------------------------------------
# 生成音声の保存先。相対パスはサーバー起動時のカレントディレクトリ基準で解決される。
TTS_AUDIO_DIR=audio
# レスポンスの url を絶対URLで返す場合に設定 (例: http://192.168.1.50:8000)。
# 空の場合は "/audio/xxxx.wav" のような相対パスを返す。
# Windows クライアントから使う場合は Mac の LAN IP を設定すると便利。
TTS_PUBLIC_BASE_URL=

# --- 音声生成の既定値 -------------------------------------------------------
# 空 = say のシステム既定音声を使用 (例: Kyoko)
TTS_DEFAULT_VOICE=
# 0 = say の既定速度を使用 (語/分)
TTS_DEFAULT_RATE=0
# 既定の出力フォーマット: aiff / wav / m4a / mp3
TTS_DEFAULT_FORMAT=m4a

# --- 入力制限 ---------------------------------------------------------------
TTS_MAX_TEXT_LENGTH=2000
TTS_RATE_MIN=100
TTS_RATE_MAX=400

# --- キャッシュ・クリーンアップ ---------------------------------------------
# ファイルの最終アクティビティ (生成 or アクセス) からの保持時間(秒)
# ダウンロード後は atime が更新されるため、実質「最終アクセスから X 秒」で削除される
TTS_AUDIO_TTL_SECONDS=60
# クリーンアップ処理の実行間隔(秒)
TTS_CLEANUP_INTERVAL_SECONDS=15
# mode=file で直接配信した後、ファイルを削除するまでの猶予(秒)
TTS_POST_SERVE_DELETE_DELAY=5

# --- 同時実行・タイムアウト -------------------------------------------------
# 同時に実行する say / ffmpeg プロセスの上限
TTS_MAX_CONCURRENT_SYNTHESIS=4
# 1回の音声生成のタイムアウト(秒)
TTS_SYNTHESIS_TIMEOUT_SECONDS=30

# --- 外部コマンド -----------------------------------------------------------
# mp3 出力時に使用。PATH 上にない場合は絶対パスを指定する。
TTS_FFMPEG_PATH=ffmpeg
